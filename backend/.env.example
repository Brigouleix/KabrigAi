# Envoi d'emails via Gmail.
# 1. Active la validation en 2 etapes sur ton compte Google
# 2. Cree un "mot de passe d'application" : https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Controle total Spotify (optionnel).
# 1. https://developer.spotify.com/dashboard -> Create app
# 2. Redirect URI : http://127.0.0.1:8000/api/spotify/callback
# 3. Copie le Client ID ci-dessous
SPOTIFY_CLIENT_ID=
